---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import '../../styles/essays.css';

export async function getStaticPaths() {
  const essays = (await getCollection('essays'))
    .filter((e) => !e.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return essays.map((entry, i) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      newer: essays[i - 1] ?? null, // more recent
      older: essays[i + 1] ?? null, // less recent
    },
  }));
}

const { entry, newer, older } = Astro.props;
const { Content } = await entry.render();
const ogImage = `https://rudder-og.b-cdn.net/og.png?title=${encodeURIComponent(entry.data.title)}&kicker=${encodeURIComponent(entry.data.topic || 'Essay')}&theme=mc`;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---
<Base title={`${entry.data.title} — Matthew Crist`} description={entry.data.description} ogImage={ogImage}>
<main>
  <article class="essay-article">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": entry.data.title,
      "description": entry.data.description,
      "datePublished": entry.data.date.toISOString(),
      "author": { "@type": "Person", "name": "Matthew Crist", "url": "https://matthewcrist.com" },
      "mainEntityOfPage": `https://matthewcrist.com/essays/${entry.slug}`
    })} is:inline />
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Essays', href: '/essays' }, { label: entry.data.title }]} />

    <header class="essay-head">
      <div class="meta">
        <span class="topic">{entry.data.topic}</span><span class="sep">·</span>
        <span>{fmt(entry.data.date)}</span>
      </div>
      <h1>{entry.data.title}</h1>
    </header>

    <div class="prose essay-body">
      <Content />
    </div>

    <footer class="essay-foot">
      {(newer || older) && (
        <nav class="pager">
          {older ? (
            <a class="prev" href={`/essays/${older.slug}`}>
              <span class="lbl">← Older</span>
              <span class="ttl">{older.data.title}</span>
            </a>
          ) : <span></span>}
          {newer ? (
            <a class="next" href={`/essays/${newer.slug}`}>
              <span class="lbl">Newer →</span>
              <span class="ttl">{newer.data.title}</span>
            </a>
          ) : <span></span>}
        </nav>
      )}
      <p style="margin-top:var(--s-6)"><a class="back" href="/essays">← All essays</a></p>
    </footer>
  </article>
</main>
</Base>
