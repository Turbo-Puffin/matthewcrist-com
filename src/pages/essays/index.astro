---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import '../../styles/essays.css';

const all = (await getCollection('essays'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const topics = Array.from(new Set(all.map((e) => e.data.topic))).sort();

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: '2-digit', timeZone: 'UTC' });
---
<Base title="Essays — Matthew Crist" description="Essays on living with less and finding peace — the constraint that quietly becomes an advantage.">
<main>
  <div class="wrap essays-head">
    <p class="eyebrow"><span class="num">02</span> &nbsp;Writing</p>
    <h1>Essays</h1>
    <p class="lead">Short notes on living and working with less — and the peace that turns out to be hiding inside the constraint.</p>

    <div class="topics" role="group" aria-label="Filter essays by topic">
      <button class="topic-chip is-active" data-topic="all" aria-pressed="true">All</button>
      {topics.map((t) => (
        <button class="topic-chip" data-topic={t} aria-pressed="false">{t}</button>
      ))}
    </div>
  </div>

  <div class="wrap essays-list">
    <div class="rows" id="essay-rows">
      {all.map((e) => (
        <a class="row-item" href={`/essays/${e.slug}`} data-topic={e.data.topic}>
          <span class="row-meta">{fmt(e.data.date)}<br />{e.data.topic}</span>
          <span class="row-main">
            <span class="row-title">{e.data.title}</span>
            <span class="row-desc">{e.data.description}</span>
          </span>
          <span class="row-arrow">→</span>
        </a>
      ))}
    </div>
    <p class="essays-empty" id="essays-empty" hidden>No essays in that topic yet.</p>
  </div>
</main>

<script is:inline>
  (function () {
    var chips = document.querySelectorAll('.topic-chip');
    var rows = Array.prototype.slice.call(document.querySelectorAll('#essay-rows .row-item'));
    var empty = document.getElementById('essays-empty');
    function apply(topic) {
      var shown = 0;
      rows.forEach(function (r) {
        var match = topic === 'all' || r.getAttribute('data-topic') === topic;
        r.hidden = !match;
        if (match) shown++;
      });
      if (empty) empty.hidden = shown !== 0;
    }
    chips.forEach(function (chip) {
      chip.addEventListener('click', function () {
        chips.forEach(function (c) { c.classList.remove('is-active'); c.setAttribute('aria-pressed', 'false'); });
        chip.classList.add('is-active');
        chip.setAttribute('aria-pressed', 'true');
        apply(chip.getAttribute('data-topic'));
      });
    });
  })();
</script>
</Base>
