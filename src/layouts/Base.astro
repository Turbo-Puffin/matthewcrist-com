---
import '../styles/tokens.css';
import '../styles/styles.css';
import '../styles/home.css';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}
const {
  title,
  description = 'Matthew Crist writes and talks about living with less and finding peace — the constraint that quietly becomes an advantage. Author of Constraint Advantage, host of The Lag.',
  bodyClass = '',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<meta name="theme-color" content="#f6f3ec" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#2a2722" media="(prefers-color-scheme: dark)" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Matthew Crist" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;500;600;700&family=Newsreader:ital,wght@0,400;0,500;0,600;1,400&family=Spline+Sans+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
<script is:inline>
  /* Set theme before paint — saved choice wins, else follow the OS. */
  (function () {
    try {
      var saved = localStorage.getItem('mc-theme');
      var sysDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.setAttribute('data-theme', saved || (sysDark ? 'dark' : 'light'));
    } catch (e) {}
  })();
</script>
</head>
<body class={bodyClass}>

<input class="site-menu-toggle" type="checkbox" id="site-menu" aria-label="Toggle menu" />

<header class="topbar">
  <div class="wrap topbar-in">
    <a class="wordmark" href="/">Matthew Crist</a>
    <div class="bar-right">
      <nav class="topnav">
        <a href="/essays">Writing</a>
        <a href="/#listen">The Lag</a>
        <a href="/#work">Uncluttah</a>
        <a href="/#book">The Book</a>
        <a href="/#about">About</a>
        <a class="btn btn-primary btn-sm nav-cta" href="/#subscribe">Subscribe</a>
      </nav>
      <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle light / dark">
        <svg class="ic-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19"></path></svg>
        <svg class="ic-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path></svg>
      </button>
      <label class="site-burger" for="site-menu" aria-label="Open menu"><span></span><span></span><span></span></label>
    </div>
  </div>
</header>
<div class="site-drawer">
  <nav>
    <a href="/essays">Writing</a>
    <a href="/#listen">The Lag</a>
    <a href="/#work">Uncluttah</a>
    <a href="/#book">The Book</a>
    <a href="/#about">About</a>
    <div class="drawer-cta"><a class="btn btn-primary" style="width:100%;justify-content:center" href="/#subscribe">Subscribe</a></div>
  </nav>
</div>

<slot />

<footer class="home-footer">
  <div class="wrap">
    <div class="cols">
      <div class="brandcol">
        <a class="wordmark" href="/">Matthew Crist</a>
        <p>Making room for what matters — one fewer thing at a time.</p>
      </div>
      <div>
        <h4>Read</h4>
        <ul>
          <li><a href="/essays">Essays</a></li>
          <li><a href="/#book">The book</a></li>
          <li><a href="/#subscribe">Newsletter</a></li>
        </ul>
      </div>
      <div>
        <h4>Listen &amp; do</h4>
        <ul>
          <li><a href="/#listen">The Lag</a></li>
          <li><a href="/#work">Uncluttah</a></li>
          <li><a href="/#about">About</a></li>
        </ul>
      </div>
      <div>
        <h4>Elsewhere</h4>
        <ul>
          <li><a href="https://x.com/heymatthewcrist" target="_blank" rel="me noopener">X</a></li>
          <li><a href="https://www.instagram.com/heymatthewcrist" target="_blank" rel="me noopener">Instagram</a></li>
          <li><a href="https://www.tiktok.com/@heymatthewcrist" target="_blank" rel="me noopener">TikTok</a></li>
          <li><a href="https://www.linkedin.com/in/heymatthewcrist" target="_blank" rel="me noopener">LinkedIn</a></li>
        </ul>
      </div>
    </div>
    <div class="base">
      <span>© 2026 Matthew Crist</span>
      <span class="mono">Made with room to breathe</span>
    </div>
  </div>
</footer>

<script is:inline>
  /* Light / dark toggle — persists the user's choice; follows the OS until they choose. */
  (function () {
    var root = document.documentElement;
    var btn = document.getElementById('theme-toggle');
    var mq = window.matchMedia ? window.matchMedia('(prefers-color-scheme: dark)') : null;
    function set(theme, save) {
      root.classList.add('theme-swapping');
      root.setAttribute('data-theme', theme);
      void root.offsetWidth; /* force reflow so colors repaint without transition */
      requestAnimationFrame(function () { root.classList.remove('theme-swapping'); });
      if (save) { try { localStorage.setItem('mc-theme', theme); } catch (e) {} }
      if (btn) btn.setAttribute('aria-pressed', theme === 'dark');
    }
    if (btn) btn.addEventListener('click', function () {
      set(root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark', true);
    });
    if (mq) mq.addEventListener('change', function (e) {
      try { if (localStorage.getItem('mc-theme')) return; } catch (err) {}
      set(e.matches ? 'dark' : 'light', false);
    });
  })();
</script>

<script is:inline>
  /* Newsletter signup → Bunny edge script → Kit. Audience is tagged server-side by Origin. */
  (function () {
    var ENDPOINT = 'https://subscribe.matthewcrist.com/';
    function setMsg(form, msg) {
      var el = form.querySelector('.subscribe-error');
      if (!el) { el = document.createElement('p'); el.className = 'subscribe-error'; form.appendChild(el); }
      el.textContent = msg;
    }
    document.querySelectorAll('form[data-subscribe]').forEach(function (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var input = form.querySelector('input[type=email]');
        var btn = form.querySelector('button[type=submit]') || form.querySelector('button');
        var email = ((input && input.value) || '').trim();
        if (!email) { if (input) input.focus(); return; }
        var original = btn ? btn.textContent : '';
        if (btn) { btn.disabled = true; btn.textContent = 'Joining…'; }
        fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email })
        }).then(function (res) {
          return res.json().catch(function () { return {}; }).then(function (data) {
            return { ok: res.ok && data && data.ok, error: data && data.error };
          });
        }).then(function (r) {
          if (r.ok) {
            form.innerHTML = '<p class="subscribe-done">You\'re on the list. Talk soon.</p>';
          } else {
            if (btn) { btn.disabled = false; btn.textContent = original; }
            setMsg(form, r.error || 'Something went wrong. Please try again.');
          }
        }).catch(function () {
          if (btn) { btn.disabled = false; btn.textContent = original; }
          setMsg(form, 'Network hiccup. Please try again.');
        });
      });
    });
  })();
</script>
</body>
</html>
